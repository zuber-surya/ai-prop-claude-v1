# Local Postgres via docker-compose.yml (service "db", mapped to host port 5433 to avoid
# colliding with other local Postgres containers on the default 5432).
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/property_website?schema=public"

# --- Auth ---
# Secret used to sign session cookies/tokens (auth library chosen in Phase 1). Generate a random 32+ char string.
AUTH_SECRET="replace-with-a-random-secret"

# --- LLM ---
# Anthropic API key (direct, not Bedrock — see CLAUDE.md §4)
ANTHROPIC_API_KEY="sk-ant-..."

# --- Map / Geocoding ---
# No API key needed for OpenStreetMap tiles + Leaflet.js.
# If server-side geocoding is used (address -> lat/lng via Nominatim, see SCHEMA.md §note), set a contact
# email/User-Agent string per OSM's usage policy:
NOMINATIM_USER_AGENT="property-website-mvp (your-email@example.com)"

# --- App ---
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Rate limiting (chat + auth endpoints, see NFR.md §4) ---
# Values are placeholders — tune during Phase 3/1 build.
CHAT_RATE_LIMIT_PER_MINUTE="10"
AUTH_RATE_LIMIT_PER_MINUTE="5"

# --- Currency ---
# INR only for this MVP (see CLAUDE.md §4). No env var needed unless a future
# multi-currency requirement changes this — left here as a documented assumption, not a toggle.
